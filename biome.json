{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 120,
		"formatWithErrors": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useAltText": "off"
			}
		}
	},
	"html": {
		"formatter": {
			"enabled": true,
			"indentStyle": "tab",
			"lineWidth": 120,
			"attributePosition": "multiline"
		}
	},
	"json": {
		"formatter": {
			"enabled": true,
			"indentStyle": "tab"
		}
	},
	"files": {
		"includes": ["html/**", "*.json", "*.md"]
	},
	"overrides": [
		{
			"includes": ["**/*.html"],
			"formatter": {
				"formatWithErrors": true
			},
			"html": {
				"parser": {
					"interpolation": false
				}
			}
		}
	]
}
