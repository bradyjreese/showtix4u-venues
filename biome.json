{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useAltText": "off"
			}
		}
	},
	"html": {
		"parser": {
			"interpolation": true
		},
		"formatter": {
			"enabled": true,
			"indentStyle": "tab",
			"lineWidth": 120,
			"attributePosition": "multiline"
		}
	},
	"json": {
		"formatter": {
			"enabled": true,
			"indentStyle": "tab"
		}
	},
	"files": {
		"includes": ["html/**", "*.json", "*.md"]
	}
}
