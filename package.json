{
  "name": "showtix4u-venues",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write --ignore-unknown --cache .",
    "format:check": "prettier --check --ignore-unknown --cache .",
    "typecheck": "pnpm --filter venue-builder exec tsc --noEmit",
    "check": "pnpm format:check && pnpm typecheck",
    "dev": "pnpm --filter venue-builder dev",
    "upload": "./scripts/upload-venue.sh",
    "download": "./scripts/download-venue.sh"
  },
  "packageManager": "pnpm@11.5.0",
  "devDependencies": {
    "prettier": "^3.9.5"
  }
}
