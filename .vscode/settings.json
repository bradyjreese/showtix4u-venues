{
  // HTML templates use Handlebars {{{ }}} — disable built-in validation
  "html.validate.scripts": false,
  "html.validate.styles": false,

  // Use djlint for HTML formatting (matches pnpm check)
  "[html]": {
    "editor.defaultFormatter": "monosans.djlint",
    "editor.formatOnSave": true
  },

  // Use project-local .venv Python
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "djlint.useVenv": false,
  "djlint.pythonPath": "/Users/bradyjreese/Code/showtix4u-venues/.venv/bin/python"
}
